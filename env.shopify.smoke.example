# Copy to .env.shopify.smoke (gitignored) — never commit real values.
# Or set the same keys in project .env (see app/core/config.py).
# Then:  cd Z:\ComAI\ComAI && python scripts\shopify_backend_smoke.py

SHOPIFY_SMOKE_DOMAIN=your-store.myshopify.com
# Prefer a static Admin token from the custom app (shpat_ or shpca_):
SHOPIFY_SMOKE_ACCESS_TOKEN=shpat_replace_me
# If you leave SHOPIFY_SMOKE_ACCESS_TOKEN empty, set both OAuth fields (API key + shpss_ secret):
# SHOPIFY_APP_CLIENT_ID=
# SHOPIFY_APP_CLIENT_SECRET=
SHOPIFY_SMOKE_WEBHOOK_SECRET=replace_me_optional_for_comai_webhooks_only

# --- Backend POST /api/v1/stores/onboard (default: OAuth only) ---
# Send domain + client_id + client_secret; omit webhook_secret to default it to client_secret.
# Legacy: token (shpat_) + webhook_secret. Never put shpss_ in token.
