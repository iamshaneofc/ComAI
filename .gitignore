# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments (any name: .venv, .venv312, etc.)
.venv*/
venv/
env/
ENV/
.history/

# Environment variables — NEVER commit these
.env
.env.*
!.env.example
!.env.*.example
.env.shopify.smoke
.env.local
.env.production
.env.staging

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Testing
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/
.hypothesis/

# Celery / local task broker state
celerybeat-schedule
celerybeat-schedule.*
celerybeat.pid

# Local data dumps / exports (do not commit customer or catalog exports)
*_export.csv
*_products_export.csv
exports/

# Alembic
migrations/versions/__pycache__/

# Distribution
dist/
build/
*.egg-info/

# Logs
*.log
logs/

# Docker
docker-compose.override.yml

# OS
.DS_Store
Thumbs.db

# Next.js (admin dashboard)
admin/node_modules/
admin/.next/
admin/out/
admin/.turbo/
admin/.vercel/

# Local databases / caches
*.sqlite3
*.db

# Cursor / local editor (optional; keeps machine-specific paths out of commits)
.cursor/

# Python version pinning (local pyenv)
.python-version
